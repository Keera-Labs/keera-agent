{
  "allow": [
    "Read(*)",
    "Edit(*)",
    "Write(*)",
    "Glob(*)",
    "Grep(*)",
    "Bash(git *)",
    "Bash(gh *)"
  ],
  "deny": [
    "Bash(rm -rf /)",
    "Bash(rm -rf /*)",
    "Bash(sudo *)",
    "Bash(su *)",
    "Bash(dd *)",
    "Bash(mkfs *)",
    "Bash(docker system prune *)"
  ]
}

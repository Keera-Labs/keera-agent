APP_ENV=desktop
KEERA_APP_URL=http://127.0.0.1:14545

DB_CONNECTION=sqlite

BROADCAST_DRIVER=reverb
REVERB_APP_ID=1
REVERB_APP_KEY=local
REVERB_APP_SECRET=secret
REVERB_SCHEME=http

# Jira plugin (optional — required only when the Jira plugin is active).
# Left commented so these placeholders never override real values loaded from
# the base .env. Uncomment and fill in to connect Jira from the packaged app:
# JIRA_BASE_URL=https://your-domain.atlassian.net
# JIRA_USERNAME=you@example.com
# JIRA_TOKEN=your-atlassian-api-token
